#!/usr/bin/env python3
"""cortex — routing decision log and self-learning loop for Cortex.

Subcommands:
  log          append a routing decision (named-flag form)
  log-line     append a routing decision from a natural routing line
  show         display recent routes with reasoning (filterable by --project)
  learn        detect patterns in the log; writes Obsidian proposals
  reroute      mark the last entry as corrected
  outcome      set the last entry's outcome (shipped / abandoned / partial / corrected)
  hint         surface similar past routes for a task, weighted by outcome
  audit-tiers  list L3/L4 routes so you can check whether L2 would have sufficed
  doctor       audit cortex setup for drift between docs, skills, and log
"""
import argparse
import hashlib
import json
import os
import re
import shutil
import sys
from collections import Counter, defaultdict
from datetime import datetime, timezone
from pathlib import Path

# State directory. CORTEX_HOME is the tool-neutral override (use it with any agent);
# CLAUDE_DIR is kept for backward compatibility; default is ~/.claude so existing
# Claude Code installs are unchanged.
CLAUDE_DIR = Path(
    os.environ.get("CORTEX_HOME")
    or os.environ.get("CLAUDE_DIR")
    or (Path.home() / ".claude")
)
LOG_PATH = CLAUDE_DIR / "cortex-log.jsonl"
CORTEX_MD = CLAUDE_DIR / "cortex.md"
SKILLS_DIR = CLAUDE_DIR / "skills"
BIN_PATH = CLAUDE_DIR / "bin" / "cortex"
DOCTOR_LAST_RUN = CLAUDE_DIR / "cortex-doctor-last-run"

# Optional Obsidian surface — only checked by doctor; absent is a soft-warn, not fail
OBSIDIAN_ROOT_ENV = os.environ.get("CORTEX_OBSIDIAN_ROOT")
OBSIDIAN_ROOT = Path(OBSIDIAN_ROOT_ENV) if OBSIDIAN_ROOT_ENV else None
PROPOSALS_DIR = (OBSIDIAN_ROOT / "proposals") if OBSIDIAN_ROOT else (CLAUDE_DIR / "cortex-proposals")

PATTERN_THRESHOLD = 3
WEEKLY_GATE_DAYS = 7
EXPECTED_SKILLS = ["cortex-log", "cortex-learn", "cortex-reroute"]
OUTCOME_STATES = ["shipped", "abandoned", "partial", "corrected"]


def now_iso():
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def session_id():
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H")


def task_hash(task):
    normalized = " ".join(task.lower().split())
    return hashlib.sha256(normalized.encode()).hexdigest()[:12]


def project_name():
    try:
        return Path(os.getcwd()).name
    except Exception:
        return "unknown"


def read_log():
    if not LOG_PATH.exists():
        return []
    entries = []
    with LOG_PATH.open() as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                entries.append(json.loads(line))
            except json.JSONDecodeError:
                continue
    return entries


def append_entry(entry):
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with LOG_PATH.open("a") as f:
        f.write(json.dumps(entry) + "\n")


def make_entry(task, classification, system, pattern, agent, tier,
               tier_reason, system_reason, project, redirect_from,
               confidence=None, route_confidence=None, tier_confidence=None,
               spec_confidence=None):
    # Backwards compat: a single --confidence value seeds all three dimensions
    # unless the caller passes the specific flags explicitly.
    rc = route_confidence or confidence
    tc = tier_confidence or confidence
    sc = spec_confidence or confidence
    return {
        "ts": now_iso(),
        "session_id": session_id(),
        "project": project or project_name(),
        "task": task,
        "task_hash": task_hash(task),
        "class": classification,
        "system": system,
        "pattern": pattern,
        "agent": agent,
        "tier": tier,
        "tier_reason": tier_reason,
        "system_reason": system_reason,
        "confidence": confidence,          # kept for backwards compat with old log entries
        "route_confidence": rc,
        "tier_confidence": tc,
        "spec_confidence": sc,
        "outcome": None,
        "redirect_from": redirect_from,
        "user_correction": None,
    }


def flag_low_confidence(entry):
    """Surface auto-trigger hints when any confidence dimension is low.
    Spec low  → recommend a requirements interview before executing.
    Tier low  → recommend a post-hoc `cortex audit-tiers` review.
    Route low → recommend rerunning `cortex hint` with a broader similarity floor.
    """
    triggers = []
    if entry.get("spec_confidence") == "low":
        triggers.append("spec_confidence=low → clarify requirements before executing")
    if entry.get("tier_confidence") == "low":
        triggers.append("tier_confidence=low → flagged for audit-tiers review")
    if entry.get("route_confidence") == "low":
        triggers.append("route_confidence=low → consider rerunning `cortex hint` with --min-similarity 0.05")
    for t in triggers:
        print(f"  [cortex] {t}", file=sys.stderr)


def cmd_log(args):
    entry = make_entry(
        task=args.task,
        classification=args.classification,
        system=args.system,
        pattern=args.pattern,
        agent=args.agent,
        tier=args.tier,
        tier_reason=args.tier_reason,
        system_reason=args.system_reason,
        project=args.project,
        redirect_from=args.redirect_from,
        confidence=args.confidence,
        route_confidence=args.route_confidence,
        tier_confidence=args.tier_confidence,
        spec_confidence=args.spec_confidence,
    )
    append_entry(entry)
    flag_low_confidence(entry)
    print(f"logged: {args.system} > {args.pattern} @ {args.tier}", file=sys.stderr)


# Natural-format parser for routing lines like:
#   "OMC > ralplan > Backend Architect @ L3"
#   "Direct > batched-edits @ L2  [system=local-tooling]"
#   "OMC > /team > [A ∥ B] → C @ L3"
ROUTE_RE = re.compile(
    r"^\s*(?P<system>[^>@]+?)\s*>\s*(?P<pattern>[^>@]+?)"
    r"(?:\s*>\s*(?P<agent>[^@]+?))?"
    r"\s*@\s*(?P<tier>L[1-4])"
    r"(?:\s*\[(?P<tags>[^\]]+)\])?\s*$"
)


def parse_route(s):
    m = ROUTE_RE.match(s)
    if not m:
        raise ValueError(
            f"unparseable route: {s!r}\n"
            f"expected format: 'System > Pattern [> Agent] @ L<n>'  (optional [tags])"
        )
    d = m.groupdict()
    return {
        "system": d["system"].strip(),
        "pattern": d["pattern"].strip(),
        "agent": d["agent"].strip() if d["agent"] else None,
        "tier": d["tier"].strip(),
        "tags": d["tags"],
    }


def cmd_log_line(args):
    try:
        parsed = parse_route(args.route)
    except ValueError as e:
        print(f"error: {e}", file=sys.stderr)
        sys.exit(2)
    entry = make_entry(
        task=args.task,
        classification=args.classification,
        system=parsed["system"],
        pattern=parsed["pattern"],
        agent=parsed["agent"],
        tier=parsed["tier"],
        tier_reason=args.tier_reason,
        system_reason=args.system_reason,
        project=args.project,
        redirect_from=args.redirect_from,
        confidence=args.confidence,
        route_confidence=args.route_confidence,
        tier_confidence=args.tier_confidence,
        spec_confidence=args.spec_confidence,
    )
    append_entry(entry)
    flag_low_confidence(entry)
    print(f"logged: {parsed['system']} > {parsed['pattern']} @ {parsed['tier']}", file=sys.stderr)


def format_entry(e):
    ts = e.get("ts", "?")[:16].replace("T", " ")
    proj = e.get("project", "?")
    cls = e.get("class", "?")
    route = f"{e.get('system', '?')} > {e.get('pattern', '?')}"
    if e.get("agent"):
        route += f" > {e['agent']}"
    route += f" @ {e.get('tier', '?')}"
    why_parts = []
    if e.get("tier_reason"):
        why_parts.append(f"tier: {e['tier_reason']}")
    if e.get("system_reason"):
        why_parts.append(f"system: {e['system_reason']}")
    why = ", ".join(why_parts) if why_parts else "(obvious route)"
    task = e.get("task", "?")
    if len(task) > 80:
        task = task[:77] + "..."
    flags = []
    # Three-dimensional confidence — show compactly as r/t/s if any are set
    rc, tc, sc = e.get("route_confidence"), e.get("tier_confidence"), e.get("spec_confidence")
    if any([rc, tc, sc]):
        short = {"high": "H", "med": "M", "low": "L"}
        triple = f"r={short.get(rc, '?')}/t={short.get(tc, '?')}/s={short.get(sc, '?')}"
        flags.append(f"[conf {triple}]")
    elif e.get("confidence"):
        flags.append(f"[conf={e['confidence']}]")
    if e.get("redirect_from"):
        flags.append(f"(redirect from: {e['redirect_from']})")
    outcome = e.get("outcome")
    if outcome == "corrected":
        flags.append("[CORRECTED]")
    elif outcome in ("shipped", "abandoned", "partial"):
        flags.append(f"[{outcome.upper()}]")
    flag_str = "  " + " ".join(flags) if flags else ""
    return f"{ts} [{proj}] {cls}{flag_str}\n  task:  {task}\n  route: {route}\n  why:   {why}"


def cmd_show(args):
    entries = read_log()
    total_all = len(entries)
    if args.project:
        entries = [e for e in entries if e.get("project") == args.project]
    if not entries:
        if args.project:
            print(f"no routes logged for project {args.project!r}")
        else:
            print("cortex log is empty — no routes logged yet")
        return
    total = len(entries)
    entries = entries[-args.last:]
    for e in entries:
        print(format_entry(e))
        print()
    scope = f"project={args.project} ({total} of {total_all} total)" if args.project else f"{total_all} total"
    print(f"[showing last {len(entries)} — {scope}]")


def write_proposal(cls, sys_, pat, count, dominant_tier, tier_count, projects, sample_tasks):
    PROPOSALS_DIR.mkdir(parents=True, exist_ok=True)
    today = datetime.now().strftime("%Y-%m-%d")
    safe_pat = re.sub(r"[^a-z0-9]+", "-", pat.lower()).strip("-") or "pattern"
    fname = f"{today}--{cls}--{sys_}--{safe_pat}.md"
    path = PROPOSALS_DIR / fname
    if path.exists():
        return path, False
    proj_str = ", ".join(f"{p}({c})" for p, c in projects.most_common())
    sample_str = "\n".join(f"- {t}" for t in sample_tasks)
    content = f"""---
tags: [cortex, proposal]
status: pending
class: {cls}
system: {sys_}
pattern: {pat}
tier: {dominant_tier}
count: {count}
detected: {today}
---

# Proposal — {cls} → {sys_} > {pat} @ {dominant_tier}

`/cortex-learn` detected this routing pattern repeating **{count} times** in the log.
Dominant tier: **{dominant_tier}** ({tier_count}/{count}).

## Candidate shortcut for cortex.md → Decision Shortcuts

| Task Type | Default Route | Tier |
|-----------|---------------|------|
| {cls.capitalize()} task | {sys_} > {pat} | {dominant_tier} |

## Projects where this fired

{proj_str}

## Recent examples

{sample_str}

## Decision

- [ ] Approved — added to cortex.md → Decision Shortcuts
- [ ] Modified — see notes below
- [ ] Rejected — see notes below

## Notes

(add reasoning here)
"""
    path.write_text(content)
    return path, True


def cmd_learn(args):
    entries = read_log()
    active = [e for e in entries if e.get("outcome") != "corrected"]

    groups = defaultdict(list)
    for e in active:
        key = (e.get("class"), e.get("system"), e.get("pattern"))
        if None in key:
            continue
        groups[key].append(e)

    candidates = [(key, grp) for key, grp in groups.items() if len(grp) >= args.threshold]
    candidates.sort(key=lambda x: -len(x[1]))

    if args.check:
        if candidates:
            (cls, sys_, pat), grp = candidates[0]
            print(f"[cortex-learn] {len(grp)} {cls} tasks routed to {sys_} > {pat} — run /cortex-learn to review")
        return

    total = len(entries)
    if not candidates:
        print(f"no patterns yet (threshold: ≥{args.threshold}, total routes logged: {total})")
        if total > 0:
            need = args.threshold - max((len(g) for g in groups.values()), default=0)
            if need > 0:
                print(f"need {need} more of the same (class, system, pattern) combo to surface a pattern")
        print(f"\nlearning activates automatically when a routing pattern repeats {args.threshold}+ times.")
        return

    print(f"found {len(candidates)} pattern(s) above threshold {args.threshold}:\n")
    written = []
    for (cls, sys_, pat), grp in candidates:
        count = len(grp)
        tiers = Counter(e.get("tier") for e in grp)
        dominant_tier, tier_count = tiers.most_common(1)[0]
        projects = Counter(e.get("project") for e in grp)
        sample_tasks = [e.get("task", "?")[:70] for e in grp[-3:]]
        print(f"• {cls} → {sys_} > {pat}   ×{count}   (tier: {dominant_tier} in {tier_count}/{count})")
        print(f"  projects: {', '.join(f'{p}({c})' for p, c in projects.most_common())}")
        print(f"  candidate shortcut for cortex.md:")
        print(f"    | {cls.capitalize()} task | {sys_} > {pat} | {dominant_tier} |")
        print(f"  recent examples:")
        for t in sample_tasks:
            print(f"    - {t}")
        if not args.no_proposals:
            try:
                path, created = write_proposal(cls, sys_, pat, count, dominant_tier, tier_count, projects, sample_tasks)
                if created:
                    written.append(path)
                    print(f"  proposal written: {path.name}")
                else:
                    print(f"  proposal exists:  {path.name}")
            except OSError as e:
                print(f"  could not write proposal ({e}) — proposal folder may be inaccessible")
        print()
    print("approve a proposal by editing it (status: approved) and adding the shortcut to cortex.md → Decision Shortcuts.")
    if written:
        print(f"\n{len(written)} new proposal(s) written to {PROPOSALS_DIR}")


def cmd_reroute(args):
    entries = read_log()
    if not entries:
        print("no entries to reroute")
        return
    last = entries[-1]
    prev_route = f"{last.get('system', '?')} > {last.get('pattern', '?')} @ {last.get('tier', '?')}"
    last["outcome"] = "corrected"
    last["user_correction"] = args.to
    LOG_PATH.write_text("".join(json.dumps(e) + "\n" for e in entries))
    print(f"marked last route as corrected: {prev_route} → {args.to}")
    print("next /cortex log call should pass --redirect-from to link the corrected entry to the new route")


def cmd_outcome(args):
    entries = read_log()
    if not entries:
        print("cortex log is empty — nothing to mark")
        return 0
    # Target this project's route, not the globally-last entry: concurrent
    # sessions in other projects log interleaved, so entries[-1] can belong to
    # someone else's route. Prefer the latest still-open entry for the current
    # project; fall back to the project's latest entry, then to the global last.
    proj = project_name()
    pool = [e for e in entries if e.get("project") == proj] or entries
    open_entries = [e for e in pool if not e.get("outcome")]
    last = (open_entries or pool)[-1]
    if last.get("outcome") == "corrected":
        print(f"last entry is already marked corrected (user_correction={last.get('user_correction')!r}); leaving as-is")
        return 0
    prev = last.get("outcome")
    last["outcome"] = args.state
    if args.note:
        last["outcome_note"] = args.note
    LOG_PATH.write_text("".join(json.dumps(e) + "\n" for e in entries))
    route = f"{last.get('system', '?')} > {last.get('pattern', '?')} @ {last.get('tier', '?')}"
    if prev:
        print(f"updated outcome: {route}  ({prev} → {args.state})")
    else:
        print(f"marked outcome: {route}  → {args.state}")
    return 0


def tokens(s):
    # Cheap tokenizer for similarity scoring — lowercase, strip punctuation, drop short/stopword tokens.
    stop = {"the", "and", "for", "with", "this", "that", "from", "into", "onto",
            "a", "an", "of", "in", "on", "at", "to", "is", "be", "as", "by",
            "or", "if", "it", "but", "not", "so", "do", "we", "i", "my", "me"}
    out = set()
    for tok in re.split(r"[^a-z0-9]+", s.lower()):
        if len(tok) >= 3 and tok not in stop:
            out.add(tok)
    return out


# Outcome weighting for hint scoring: past successes add signal, corrections subtract.
OUTCOME_WEIGHTS = {"shipped": 1.0, "partial": 0.5, "corrected": -1.0, "abandoned": -0.5}
UNSCORED_WEIGHT = 0.3  # entry logged but never given an outcome


def cmd_hint(args):
    """Phase 3 (advisory mode): given a task description, surface similar past routes
    weighted by outcome. Does NOT decide — returns evidence to factor into the route.

    Filter by --tier or --class to narrow the comparison pool. Note that on a small
    log, filtering by both fragments the pool into buckets too small to be useful —
    prefer --class alone until the per-class pools are comfortably above ~15 entries.
    """
    entries = read_log()
    if not entries:
        print("cortex log is empty — no hint available yet")
        return 0

    target = tokens(args.task)
    if not target:
        print("task too short to score similarity")
        return 0

    # Filter the pool first — drastically improves signal vs noise
    pool = entries
    if args.tier:
        pool = [e for e in pool if e.get("tier") == args.tier]
    if args.classification:
        pool = [e for e in pool if e.get("class") == args.classification]
    if not pool:
        filters = []
        if args.tier:
            filters.append(f"tier={args.tier}")
        if args.classification:
            filters.append(f"class={args.classification}")
        print(f"no past entries match filter ({', '.join(filters)})")
        return 0

    scored = []
    for e in pool:
        toks = tokens(e.get("task", ""))
        if not toks:
            continue
        jaccard = len(target & toks) / len(target | toks)
        if jaccard >= args.min_similarity:
            scored.append((jaccard, e))

    if not scored:
        print(f"no similar past tasks (similarity ≥ {args.min_similarity}, pool size {len(pool)})")
        return 0

    scored.sort(key=lambda x: -x[0])
    top = scored[: args.top]

    # Tally routes among top matches; weight each by its outcome
    tally = defaultdict(float)
    for sim, e in top:
        route = (e.get("system"), e.get("pattern"), e.get("tier"))
        tally[route] += sim * OUTCOME_WEIGHTS.get(e.get("outcome"), UNSCORED_WEIGHT)

    print(f"hint for: {args.task!r}\n")
    print(f"top {len(top)} similar past tasks (similarity ≥ {args.min_similarity}):")
    for sim, e in top:
        outcome = e.get("outcome") or "no-outcome"
        route = f"{e.get('system', '?')} > {e.get('pattern', '?')} @ {e.get('tier', '?')}"
        print(f"  [{sim:.2f}] [{outcome}] {route}")
        print(f"         task: {e.get('task', '?')[:80]}")
    print()

    ranked = sorted(tally.items(), key=lambda x: -x[1])
    print("suggested routes (weighted by outcome):")
    for (sys_, pat, tier), score in ranked[:3]:
        print(f"  score={score:+.2f}  {sys_} > {pat} @ {tier}")
    print()
    print("advisory only — you still pick the final route. negative scores mean past attempts "
          "at that route failed or were corrected.")
    return 0


def cmd_audit_tiers(args):
    """List every L3/L4 (or filtered tier) entry with task + reasoning + outcome, so you
    can eyeball whether L2 would have sufficed and feed corrections back via --reclassify.
    """
    entries = read_log()
    if args.reclassify_hash:
        if not args.reclassify_to:
            print("--reclassify requires --to <L1|L2|L3|L4>", file=sys.stderr)
            return 2
        for e in entries:
            if e.get("task_hash") == args.reclassify_hash:
                original = e.get("tier")
                e["tier_audit_original"] = original
                e["tier"] = args.reclassify_to
                e["tier_audit_note"] = args.note
                LOG_PATH.write_text("".join(json.dumps(x) + "\n" for x in entries))
                print(f"reclassified {args.reclassify_hash}: {original} → {args.reclassify_to}")
                return 0
        print(f"no entry with task_hash={args.reclassify_hash!r}")
        return 1

    if not entries:
        print("cortex log is empty — nothing to audit")
        return 0

    tiers_to_show = args.tier or ["L3", "L4"]
    filtered = [e for e in entries if e.get("tier") in tiers_to_show]
    if not filtered:
        print(f"no entries at tier(s) {','.join(tiers_to_show)}")
        return 0

    total = len(entries)
    outcomes = Counter(e.get("outcome") for e in filtered)
    by_tier = Counter(e.get("tier") for e in filtered)

    print(f"tier audit — {len(filtered)} of {total} routes at tiers {','.join(tiers_to_show)}")
    print(f"  by tier:    {dict(by_tier)}")
    print(f"  by outcome: {dict(outcomes)}\n")

    for e in filtered:
        ts = e.get("ts", "?")[:10]
        h = e.get("task_hash", "?")
        tier = e.get("tier", "?")
        outcome = e.get("outcome") or "no-outcome"
        route = f"{e.get('system', '?')} > {e.get('pattern', '?')}"
        task = e.get("task", "?")
        if len(task) > 90:
            task = task[:87] + "..."
        print(f"  {ts}  {h}  [{tier}] [{outcome}]  {route}")
        print(f"           task: {task}")
        reason = e.get("tier_reason") or "(no reason)"
        if len(reason) > 100:
            reason = reason[:97] + "..."
        print(f"           why:  {reason}")
        if e.get("tier_audit_original"):
            print(f"           [reclassified from {e['tier_audit_original']}]")
        print()

    print("to reclassify an entry to a lower tier, run:")
    print("  cortex audit-tiers --reclassify <task_hash> --to L2 [--note 'why']")
    return 0


def cmd_doctor(args):
    # Gate: in --weekly mode, skip silently if we ran within the gate window
    if args.weekly and DOCTOR_LAST_RUN.exists():
        try:
            last = datetime.fromisoformat(DOCTOR_LAST_RUN.read_text().strip().rstrip("Z")).replace(tzinfo=timezone.utc)
            if (datetime.now(timezone.utc) - last).days < WEEKLY_GATE_DAYS:
                return 0
        except (ValueError, OSError):
            pass

    issues = {"pass": [], "warn": [], "fail": []}

    # Check 1 — skills wired
    for skill in EXPECTED_SKILLS:
        skill_path = SKILLS_DIR / skill / "SKILL.md"
        if skill_path.exists():
            issues["pass"].append(f"skill wired: {skill}")
        else:
            issues["fail"].append(
                f"skill missing: {skill} — cortex.md documents /{skill} but {skill_path} doesn't exist"
            )

    # Check 2 — bin script present and executable
    if BIN_PATH.exists() and os.access(BIN_PATH, os.X_OK):
        issues["pass"].append("cortex CLI present and executable")
    elif BIN_PATH.exists():
        issues["warn"].append(f"cortex CLI exists but not executable: chmod +x {BIN_PATH}")
    else:
        issues["fail"].append(f"cortex CLI missing: {BIN_PATH}")

    # Check 3 — cortex.md present
    if CORTEX_MD.exists():
        issues["pass"].append(f"cortex.md present: {CORTEX_MD}")
    else:
        issues["warn"].append(f"cortex.md missing — copy templates/cortex.md to {CORTEX_MD}")

    # Check 4 — proposals folder (informational only)
    if PROPOSALS_DIR.exists():
        issues["pass"].append(f"proposals folder exists: {PROPOSALS_DIR}")
    else:
        issues["pass"].append("proposals folder will be created on first /cortex-learn run")

    # Check 5 — log entries hygiene
    entries = read_log()
    total = len(entries)
    bad = [e for e in entries if not e.get("class") or not e.get("system") or not e.get("pattern") or not e.get("tier")]
    if bad:
        issues["warn"].append(f"{len(bad)} log entry/entries missing required fields")
    elif entries:
        issues["pass"].append("all log entries have required fields")

    # Check 6 — phase progression
    if total < 20:
        issues["pass"].append(f"Phase 1 (visibility) — {total} routes logged")
    elif total < 200:
        issues["pass"].append(f"Phase 2 (pattern surfacing active) — {total} routes logged")
    else:
        issues["pass"].append(f"Phase 3 (similarity bias mature) — {total} routes logged")

    # Check 7 — outcome coverage: `hint` weights past routes by outcome, so an
    # unmarked log gives every route the same flat weight and the hints go blind.
    if entries:
        marked = sum(1 for e in entries if e.get("outcome"))
        if marked == 0:
            issues["warn"].append(
                "no route has an outcome — run `cortex outcome <shipped|abandoned|partial|corrected>` "
                "at the end of a task so `cortex hint` can weight past routes"
            )
        else:
            issues["pass"].append(f"outcome coverage: {marked}/{total} routes marked")

    # Render
    n_fail = len(issues["fail"])
    n_warn = len(issues["warn"])
    n_pass = len(issues["pass"])

    if args.weekly:
        if n_fail:
            print(f"[cortex] !! {n_fail} FAIL, {n_warn} warn — run `python3 ~/.claude/bin/cortex doctor` for details")
        elif n_warn:
            print(f"[cortex] {n_warn} warn, 0 fail — run `python3 ~/.claude/bin/cortex doctor` for details")
        else:
            phase = "Phase 1" if total < 20 else ("Phase 2" if total < 200 else "Phase 3")
            print(f"[cortex] all green ({total} routes, {phase})")
        try:
            DOCTOR_LAST_RUN.write_text(now_iso())
        except OSError:
            pass
        return 1 if n_fail else 0

    print(f"cortex doctor — {n_pass} pass, {n_warn} warn, {n_fail} fail\n")
    if issues["fail"]:
        print("FAIL")
        for m in issues["fail"]:
            print(f"  ✗ {m}")
        print()
    if issues["warn"]:
        print("WARN")
        for m in issues["warn"]:
            print(f"  ! {m}")
        print()
    if args.verbose and issues["pass"]:
        print("PASS")
        for m in issues["pass"]:
            print(f"  ✓ {m}")
        print()
    if not issues["fail"] and not issues["warn"]:
        print("all green")
    return 1 if n_fail else 0


# ---------- init: discovery scan (M1) ----------
# Files/stems that live in an agents dir but are not agents.
_NON_AGENT = {"readme", "contributing", "security", "license", "code_of_conduct", "changelog", "index"}

# Multi-tool config files to probe: (label, [relative names], [roots to check])
TOOL_CONFIGS = [
    ("Claude Code (CLAUDE.md)", ["CLAUDE.md"], [CLAUDE_DIR, Path.home(), Path.cwd()]),
    ("Codex / AGENTS.md", ["AGENTS.md"], [Path.cwd(), Path.home() / ".codex"]),
    ("Gemini CLI (GEMINI.md)", ["GEMINI.md"], [Path.cwd(), Path.home() / ".gemini", Path.home()]),
    ("Cursor (.cursor/rules)", [".cursor/rules"], [Path.cwd()]),
    ("Windsurf (.windsurf/rules)", [".windsurf/rules", ".windsurfrules"], [Path.cwd()]),
    ("Aider", [".aider.conf.yml", "CONVENTIONS.md"], [Path.cwd(), Path.home()]),
]

KNOWN_CLIS = ["claude", "codex", "gemini", "aider", "qwen", "agent-browser",
              "cursor", "windsurf", "gh", "graphify", "kronos", "docker"]


def _read_frontmatter(path):
    """Best-effort 'name'/'description' from a markdown file's YAML frontmatter."""
    try:
        text = path.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return None, None
    m = re.match(r"^---\s*\n(.*?)\n---", text, re.S)
    block = m.group(1) if m else "\n".join(text.splitlines()[:8])
    name = desc = None
    for line in block.splitlines():
        mn = re.match(r'^\s*name:\s*"?(.+?)"?\s*$', line)
        md = re.match(r'^\s*description:\s*"?(.+?)"?\s*$', line)
        if mn and not name:
            name = mn.group(1).strip()
        if md and not desc:
            desc = md.group(1).strip()
    return name, desc


def _scan_skills(base):
    items = []
    if not base.exists():
        return items
    for sub in sorted(p for p in base.iterdir() if p.is_dir()):
        f = sub / "SKILL.md"
        if f.exists():
            name, desc = _read_frontmatter(f)
            items.append({"name": name or sub.name, "description": desc})
    return items


def _scan_commands(base):
    if not base.exists():
        return []
    return sorted(f.stem for f in base.rglob("*.md") if f.stem.lower() not in _NON_AGENT)


def _scan_agents(base):
    if not base.exists():
        return {"count": 0, "divisions": {}, "sample": []}
    agents = []
    for f in base.rglob("*.md"):
        if f.stem.lower() in _NON_AGENT:
            continue
        rel = f.relative_to(base)
        division = rel.parts[0] if len(rel.parts) > 1 else "(root)"
        name, _ = _read_frontmatter(f)
        agents.append((name or f.stem, division))
    return {
        "count": len(agents),
        "divisions": dict(Counter(d for _, d in agents)),
        "sample": [n for n, _ in agents[:12]],
    }


def _scan_mcp_servers():
    """MCP servers live in a few possible files; merge whatever we find."""
    servers = set()
    for path in [CLAUDE_DIR / "settings.json", Path.home() / ".claude.json", Path.cwd() / ".mcp.json"]:
        if not path.exists():
            continue
        try:
            d = json.loads(path.read_text(encoding="utf-8"))
        except (OSError, ValueError):
            continue
        if isinstance(d.get("mcpServers"), dict):
            servers.update(d["mcpServers"].keys())
        projects = d.get("projects")
        if isinstance(projects, dict):
            for proj in projects.values():
                if isinstance(proj, dict) and isinstance(proj.get("mcpServers"), dict):
                    servers.update(proj["mcpServers"].keys())
    return sorted(servers)


def _scan_settings_meta(path):
    out = {"hooks": [], "plugins": []}
    if not path.exists():
        return out
    try:
        d = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, ValueError):
        return out
    if isinstance(d.get("hooks"), dict):
        out["hooks"] = sorted(d["hooks"].keys())
    for key in ("enabledPlugins", "enabled_plugins"):
        v = d.get(key)
        if isinstance(v, dict):
            out["plugins"] = sorted(v.keys())
        elif isinstance(v, list):
            out["plugins"] = list(v)
    return out


def _detect_tool_configs():
    found = []
    for label, rels, roots in TOOL_CONFIGS:
        for root in roots:
            hit = next((str(root / rel) for rel in rels if (root / rel).exists()), None)
            if hit:
                found.append({"tool": label, "path": hit})
                break
    return found


def build_inventory():
    meta = _scan_settings_meta(CLAUDE_DIR / "settings.json")
    return {
        "generated": now_iso(),
        "claude_dir": str(CLAUDE_DIR),
        "agents": _scan_agents(CLAUDE_DIR / "agents"),
        "skills": _scan_skills(SKILLS_DIR),
        "commands": _scan_commands(CLAUDE_DIR / "commands"),
        "mcp_servers": _scan_mcp_servers(),
        "hooks": meta["hooks"],
        "plugins": meta["plugins"],
        "tool_configs": _detect_tool_configs(),
        "clis": [c for c in KNOWN_CLIS if shutil.which(c)],
        "existing_cortex_md": CORTEX_MD.exists(),
    }


def cmd_init(args):
    inv = build_inventory()
    out_path = Path(args.out) if args.out else (CLAUDE_DIR / "cortex-inventory.json")
    if not args.dry_run:
        try:
            out_path.write_text(json.dumps(inv, indent=2), encoding="utf-8")
        except OSError as e:
            print(f"could not write {out_path}: {e}", file=sys.stderr)

    ag = inv["agents"]
    print("cortex init — discovery scan (M1)\n")
    print(f"  state dir:     {inv['claude_dir']}")
    agents_line = f"  agents:        {ag['count']}"
    if ag["divisions"]:
        agents_line += f" across {len(ag['divisions'])} divisions"
    print(agents_line)
    if ag["divisions"]:
        top = sorted(ag["divisions"].items(), key=lambda kv: -kv[1])[:6]
        print("                 " + ", ".join(f"{k} ({v})" for k, v in top))
    print(f"  skills:        {len(inv['skills'])}")
    print(f"  commands:      {len(inv['commands'])}")
    mcp = inv["mcp_servers"]
    mcp_line = f"  MCP servers:   {len(mcp)}"
    if mcp:
        mcp_line += " — " + ", ".join(mcp[:8]) + (" …" if len(mcp) > 8 else "")
    print(mcp_line)
    print(f"  hooks:         {len(inv['hooks'])} event(s)")
    print(f"  plugins:       {len(inv['plugins'])}")
    print(f"  other agents:  {', '.join(tc['tool'] for tc in inv['tool_configs']) or 'none detected'}")
    print(f"  relevant CLIs: {', '.join(inv['clis']) or 'none detected'}")
    print(f"  cortex.md:     {'exists → M4 will MERGE, never overwrite' if inv['existing_cortex_md'] else 'not present → M4 will create'}")
    if not args.dry_run:
        print(f"\n  → inventory written to {out_path}")
    print("\n  Next (not yet built): M2 interview → M3 registry synthesis → M4 merge.")
    return 0


def build_parser():
    p = argparse.ArgumentParser(prog="cortex", description="Cortex routing log & self-learning loop")
    sub = p.add_subparsers(dest="cmd", required=True)

    lg = sub.add_parser("log", help="append a routing decision (named-flag form)")
    lg.add_argument("--task", required=True)
    lg.add_argument("--class", dest="classification", required=True,
                    choices=["build", "review", "plan", "research", "debug", "design", "quickfix"])
    lg.add_argument("--system", required=True)
    lg.add_argument("--pattern", required=True)
    lg.add_argument("--agent", default=None)
    lg.add_argument("--tier", required=True, choices=["L1", "L2", "L3", "L4"])
    lg.add_argument("--tier-reason", default=None)
    lg.add_argument("--system-reason", default=None)
    lg.add_argument("--project", default=None)
    lg.add_argument("--redirect-from", default=None)
    lg.add_argument("--confidence", default=None, choices=["high", "med", "low"],
                    help="overall confidence — seeds route/tier/spec if those aren't passed individually")
    lg.add_argument("--route-confidence", default=None, choices=["high", "med", "low"],
                    help="confidence in the system+pattern choice (low → rerun hint with broader similarity)")
    lg.add_argument("--tier-confidence", default=None, choices=["high", "med", "low"],
                    help="confidence in the tier choice (low → flagged for audit-tiers review)")
    lg.add_argument("--spec-confidence", default=None, choices=["high", "med", "low"],
                    help="confidence in understanding the spec (low → clarify requirements before executing)")
    lg.add_argument("--shown-inline", action="store_true", help=argparse.SUPPRESS)
    lg.set_defaults(func=cmd_log)

    ll = sub.add_parser("log-line", help="append a routing decision from a natural routing line")
    ll.add_argument("route", help="natural format: 'System > Pattern [> Agent] @ L<n>'")
    ll.add_argument("task", help="one-line task description")
    ll.add_argument("--class", dest="classification", required=True,
                    choices=["build", "review", "plan", "research", "debug", "design", "quickfix"])
    ll.add_argument("--tier-reason", default=None)
    ll.add_argument("--system-reason", default=None)
    ll.add_argument("--project", default=None)
    ll.add_argument("--redirect-from", default=None)
    ll.add_argument("--confidence", default=None, choices=["high", "med", "low"],
                    help="overall confidence — seeds route/tier/spec if those aren't passed individually")
    ll.add_argument("--route-confidence", default=None, choices=["high", "med", "low"])
    ll.add_argument("--tier-confidence", default=None, choices=["high", "med", "low"])
    ll.add_argument("--spec-confidence", default=None, choices=["high", "med", "low"])
    ll.set_defaults(func=cmd_log_line)

    sh = sub.add_parser("show", help="display recent routes")
    sh.add_argument("--last", type=int, default=20)
    sh.add_argument("--project", default=None, help="filter by project name")
    sh.set_defaults(func=cmd_show)

    ln = sub.add_parser("learn", help="detect patterns in the log")
    ln.add_argument("--threshold", type=int, default=PATTERN_THRESHOLD)
    ln.add_argument("--check", action="store_true", help="terse one-line output for session start")
    ln.add_argument("--no-proposals", action="store_true",
                    help="skip writing proposal markdown files")
    ln.set_defaults(func=cmd_learn)

    rr = sub.add_parser("reroute", help="mark last entry as corrected")
    rr.add_argument("--to", required=True, help="the corrected route")
    rr.set_defaults(func=cmd_reroute)

    oc = sub.add_parser("outcome", help="set the last entry's outcome")
    oc.add_argument("state", choices=OUTCOME_STATES,
                    help="shipped (worked, done) / abandoned (route was wrong, moved on) / "
                         "partial (some progress, stopped before goal) / corrected (rerouted mid-flow)")
    oc.add_argument("--note", default=None, help="optional free-text note")
    oc.set_defaults(func=cmd_outcome)

    hn = sub.add_parser("hint", help="advisory: surface similar past routes for a task")
    hn.add_argument("task", help="one-line task description to find similar past routes for")
    hn.add_argument("--top", type=int, default=5, help="number of similar past tasks to consider (default 5)")
    hn.add_argument("--min-similarity", type=float, default=0.15,
                    help="minimum Jaccard similarity to count as related (default 0.15)")
    hn.add_argument("--tier", choices=["L1", "L2", "L3", "L4"],
                    help="filter past routes to a matching tier (only useful once the log is large)")
    hn.add_argument("--class", dest="classification",
                    choices=["build", "review", "plan", "research", "debug", "design", "quickfix"],
                    help="filter past routes to a matching task class")
    hn.set_defaults(func=cmd_hint)

    at = sub.add_parser("audit-tiers", help="audit L3/L4 routes — check whether L2 would have sufficed")
    at.add_argument("--tier", action="append", choices=["L1", "L2", "L3", "L4"],
                    help="tiers to include (default: L3 and L4). pass multiple times for multiple tiers")
    at.add_argument("--reclassify", dest="reclassify_hash", default=None,
                    metavar="TASK_HASH", help="reclassify a single entry by task_hash")
    at.add_argument("--to", dest="reclassify_to", choices=["L1", "L2", "L3", "L4"],
                    help="new tier (with --reclassify)")
    at.add_argument("--note", default=None, help="reason for the reclassification")
    at.set_defaults(func=cmd_audit_tiers)

    dr = sub.add_parser("doctor", help="audit cortex setup for drift between docs, skills, and log")
    dr.add_argument("-v", "--verbose", action="store_true", help="show passing checks too")
    dr.add_argument("--weekly", action="store_true",
                    help=f"compact mode for SessionStart hook; gates to run at most once per {WEEKLY_GATE_DAYS} days")
    dr.set_defaults(func=cmd_doctor)

    ini = sub.add_parser("init", help="discover your existing systems (M1: scan) to prepare a personalized registry")
    ini.add_argument("--out", help="where to write the inventory JSON (default: <state-dir>/cortex-inventory.json)")
    ini.add_argument("--dry-run", action="store_true", help="print the summary without writing the inventory file")
    ini.set_defaults(func=cmd_init)

    return p


def main():
    parser = build_parser()
    args = parser.parse_args()
    rc = args.func(args)
    sys.exit(rc or 0)


if __name__ == "__main__":
    main()
