# Cortex intake bot config. Copy to `.env` and fill in.
# `.env` is gitignored — never commit real values.

# 1. Create a DEDICATED Telegram bot via @BotFather (do NOT reuse another bot's
#    token; Telegram allows only one getUpdates consumer per token). Paste it here.
CORTEX_INBOX_BOT_TOKEN=

# 2. Telegram user ids allowed to talk to the bot (comma-separated). Message
#    @userinfobot to find yours. Anyone not listed is ignored.
CORTEX_INBOX_ALLOWED_IDS=

# Optional: chat_id for worker-initiated messages. Defaults to the first allowed
# id (correct for a 1:1 DM with the bot). Set only for group/channel use.
# CORTEX_INBOX_DEFAULT_CHAT=

# Optional: where cortex writes proposal notes. Defaults to
# $CLAUDE_DIR/cortex-proposals. Point at an Obsidian vault folder if you want.
# CORTEX_OBSIDIAN_ROOT=/path/to/your/vault/Cortex

# Optional: your Claude config dir. Defaults to ~/.claude.
# CLAUDE_DIR=
